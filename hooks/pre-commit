#!/bin/sh
# в¬Ў Okam вҖ” Pre-commit Hook
# Validates OKF compliance for staged wiki files and detects leaked secrets.
# Part of the Okam governance framework. Install via: okam hooks install

set -e

# в”Җв”Җ Colors в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
RESET='\033[0m'

ERRORS=0

# в”Җв”Җ 1. OKF Validation в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Find staged .md files in wiki directories
WIKI_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(knowledge/wiki|wiki)/.*\.md$' || true)

if [ -n "$WIKI_FILES" ]; then
    printf "${BLUE}${BOLD}в¬Ў Okam pre-commit: Validando conformidade OKF...${RESET}\n"

    # Check if okam CLI is available
    if command -v okam >/dev/null 2>&1; then
        for file in $WIKI_FILES; do
            # Validate the staged version by using the working copy
            # (okam validate works on files in the filesystem)
            WIKI_DIR=$(dirname "$file")
            RESULT=$(okam validate --wiki-dir "$WIKI_DIR" 2>&1) || true

            BASENAME=$(basename "$file")
            if echo "$RESULT" | grep -q "\[FALHA\] $BASENAME"; then
                printf "${RED}  вң— ${BASENAME}${RESET}\n"
                echo "$RESULT" | grep -A5 "\[FALHA\] $BASENAME" | grep "^    -" || true
                ERRORS=$((ERRORS + 1))
            else
                printf "${GREEN}  вң“ ${BASENAME}${RESET}\n"
            fi
        done
    else
        printf "${YELLOW}  вҡ  okam CLI nГЈo encontrado. Pulando validaГ§ГЈo OKF.${RESET}\n"
        printf "${YELLOW}    Instale com: pip install okam${RESET}\n"
    fi
fi

# в”Җв”Җ 2. Secret Detection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM || true)

if [ -n "$STAGED_FILES" ]; then
    # Check for .env files being committed
    ENV_FILES=$(echo "$STAGED_FILES" | grep -E '\.env($|\.)' | grep -v '\.env\.example$' || true)
    if [ -n "$ENV_FILES" ]; then
        printf "\n${RED}${BOLD}в¬Ў Okam pre-commit: Arquivos .env detectados!${RESET}\n"
        for f in $ENV_FILES; do
            printf "${RED}  вң— ${f}${RESET}\n"
        done
        printf "${YELLOW}  вҶ’ Adicione ao .gitignore ou use .env.example como template.${RESET}\n"
        ERRORS=$((ERRORS + 1))
    fi

    # Scan staged content for secret patterns
    SECRET_FOUND=0
    for file in $STAGED_FILES; do
        # Skip binary files and known safe extensions
        case "$file" in
            *.png|*.jpg|*.jpeg|*.gif|*.ico|*.woff|*.woff2|*.ttf|*.eot|*.svg|*.mp4|*.zip|*.tar|*.gz)
                continue
                ;;
        esac

        # Get staged content (not working copy)
        CONTENT=$(git show ":$file" 2>/dev/null) || continue

        # AWS Access Key IDs
        if echo "$CONTENT" | grep -qE 'AKIA[0-9A-Z]{16}'; then
            printf "${RED}  вң— PossГӯvel AWS Key em: ${file}${RESET}\n"
            SECRET_FOUND=1
        fi

        # OpenAI / Anthropic / Generic API keys
        if echo "$CONTENT" | grep -qE '(sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|glpat-[a-zA-Z0-9\-]{20,}|xoxb-[0-9]{10,})'; then
            printf "${RED}  вң— PossГӯvel API key/token em: ${file}${RESET}\n"
            SECRET_FOUND=1
        fi

        # Generic secret assignments (password, secret, token with long values)
        if echo "$CONTENT" | grep -qiE '(password|secret|token|api_key|apikey|private_key)\s*[=:]\s*["\x27][^\s"'\'']{12,}'; then
            printf "${RED}  вң— PossГӯvel segredo hardcoded em: ${file}${RESET}\n"
            SECRET_FOUND=1
        fi
    done

    if [ "$SECRET_FOUND" -eq 1 ]; then
        printf "\n${RED}${BOLD}в¬Ў Okam pre-commit: Segredos detectados!${RESET}\n"
        printf "${YELLOW}  вҶ’ Remova os segredos e use variГЎveis de ambiente.${RESET}\n"
        printf "${YELLOW}  вҶ’ Para scan mais robusto, considere: https://github.com/gitleaks/gitleaks${RESET}\n"
        ERRORS=$((ERRORS + 1))
    fi
fi

# в”Җв”Җ Result в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [ "$ERRORS" -gt 0 ]; then
    printf "\n${RED}${BOLD}в¬Ў Okam: Commit bloqueado вҖ” corrija os erros acima.${RESET}\n"
    printf "${YELLOW}  Para bypass emergencial: git commit --no-verify${RESET}\n"
    exit 1
fi

if [ -n "$WIKI_FILES" ]; then
    printf "${GREEN}${BOLD}в¬Ў Okam: Todas as verificaГ§Гөes passaram.${RESET}\n"
fi

exit 0
